# ── Required ──────────────────────────────────────────────────────────────────

# Base URL of the deployed todos-api service on Railway.
AGENT_BASE_URL=https://your-todos-api.up.railway.app

# Shared Postgres connection string (same DATABASE_URL as the main service).
# The runner reads agent_enrollments and writes job-run state + audit log.
# Use the internal Railway URL (postgres.railway.internal) for zero-latency access.
DATABASE_URL=postgresql://postgres:<password>@postgres.railway.internal:5432/railway

# ── Recommended ───────────────────────────────────────────────────────────────

# Postgres connection string (same DATABASE_URL used by the main service).
# When set, job-run locks and audit logs are persisted to Postgres.
# When absent, in-memory fallback is used (no persistence across restarts).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Scheduling ────────────────────────────────────────────────────────────────

# IANA timezone used for period keys and report timestamps.
TIMEZONE=America/New_York

# ── Automation policy ─────────────────────────────────────────────────────────

# Set to true to enable safe auto-apply of allowlisted actions.
# Start with false (suggest-only) and enable once you trust the output.
AUTO_APPLY=false

# Set to true to run the job without issuing any writes.
# Useful for smoke-testing config and verifying connectivity.
DRY_RUN=false

# Maximum number of write actions applied per single job run.
# Circuit-breaker: prevents runaway loops on unexpected server output.
MAX_WRITE_ACTIONS_PER_RUN=20

# ── Delivery ──────────────────────────────────────────────────────────────────

# How to deliver the job report: log | email | slack
DELIVERY_MODE=log

# Email delivery (required when DELIVERY_MODE=email)
# EMAIL_TO=you@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=smtp-user
# SMTP_PASS=smtp-password
# SMTP_FROM=agent@example.com

# Slack delivery (required when DELIVERY_MODE=slack)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Operational ───────────────────────────────────────────────────────────────

# HTTP timeout in seconds for agent API calls.
HTTP_TIMEOUT_SECONDS=60

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
