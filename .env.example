# Database URLs
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todos_dev"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/todos_test"

# Server Configuration
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_SECRET=your-access-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-jwt-secret-change-in-production
# Optional: one-time first-admin provisioning secret used by /auth/bootstrap-admin
ADMIN_BOOTSTRAP_SECRET=
# Toggle verification/reset email delivery (set false if SMTP is not configured yet)
EMAIL_FEATURES_ENABLED=true

# CORS (required in production, comma-separated origins)
# Example: CORS_ORIGINS=https://todos.karthikg.in,https://admin.example.com
CORS_ORIGINS=

# Email Configuration (for verification & password reset)
# For development, you can use Ethereal Email: https://ethereal.email/
# For production, use real SMTP (Gmail, SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-username
SMTP_PASS=your-ethereal-password
SMTP_FROM="Todo App <noreply@todoapp.com>"
# Public app/API origin. Must be the real public HTTPS base URL in production.
BASE_URL=http://localhost:3000

# Request hardening
REQUEST_BODY_LIMIT=256kb
FORM_BODY_LIMIT=64kb
REQUEST_TIMEOUT_MS=30000
HEADERS_TIMEOUT_MS=35000
KEEP_ALIVE_TIMEOUT_MS=5000

# Temporary browser session used during MCP OAuth account linking
MCP_OAUTH_SESSION_COOKIE_NAME=mcp_link_session
MCP_OAUTH_SESSION_MAX_AGE_MS=900000

# GitHub Integration (required for feedback → GitHub issue promotion)
# Create a fine-grained PAT at https://github.com/settings/tokens with Issues read/write scope
GITHUB_TOKEN=
GITHUB_REPO=karthikg80/todos-api

# AI Provider (optional; deterministic fallback is used when disabled)
AI_PROVIDER_ENABLED=false
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=gpt-4o-mini
AI_DAILY_SUGGESTION_LIMIT=50
AI_DAILY_SUGGESTION_LIMIT_FREE=50
AI_DAILY_SUGGESTION_LIMIT_PRO=250
AI_DAILY_SUGGESTION_LIMIT_TEAM=1000
